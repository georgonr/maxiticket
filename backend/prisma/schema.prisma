generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  // Platform-level (no organizerId)
  SUPERADMIN        // full platform access
  STAFF             // internal operator – creates events for clients, support

  // Tenant-scoped (organizerId required)
  ORGANIZER_OWNER   // tenant owner – full control over org + events + billing
  ORGANIZER_MEMBER  // tenant staff – limited management
  SCANNER           // door staff – scan only

  // Public
  CUSTOMER          // end buyer
}

enum OrganizerStatus {
  PENDING   // registered, awaiting approval
  ACTIVE
  SUSPENDED
}

// Fakturačný systém (krok 13a): režim vyúčtovania organizátora.
enum BillingMode {
  PER_EVENT  // vyúčtovanie po každom (skončenom) termíne
  MONTHLY    // mesačné vyúčtovanie agregátom termínov
}

// Fakturačný systém (krok 13b): faktúra organizátorovi (provízia + refund + custom).
enum InvoiceStatus {
  DRAFT       // editovateľná, bez čísla
  FINALIZED   // zamknutá, pridelené invoiceNumber
}

enum InvoiceLineType {
  COMMISSION   // provízia z predaja
  REFUND_FEE   // poplatok za refundáciu
  CUSTOM       // ručne pridaná položka
}

enum VatStatus {
  NON_PAYER
  PAYER
  REGISTERED  // registered but not yet a full payer
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  ARCHIVED
}

enum TerminStatus {
  DRAFT
  COMING_SOON
  ON_SALE
  SOLD_OUT
  CANCELLED
  PAST
}

// Režim predaja termínu (úloha 22 fáza 3a)
enum TerminMode {
  GENERAL // dnešný predaj cez TicketType (nedotknutý)
  SEATMAP // predaj cez plánik – sekcie (SECTIONED) / sedadlá (SEATED, fáza 3b)
}

enum OrderStatus {
  PENDING    // payment initiated
  PAID
  REFUND_REQUESTED  // customer požiadal o vrátenie (Úloha 20)
  REFUND_APPROVED   // schválené, čaká na vykonanie refundu (Stripe manuálne / comp-pos rovno)
  REFUND_REJECTED   // žiadosť zamietnutá (Order sa reálne vracia na PAID; hodnota pre audit/úplnosť)
  REFUND_PENDING    // krok 27: termín zrušený → čaká na manuálny refund (Stripe Dashboard / POS hotovosť)
  REFUNDED
  CANCELLED
  FAILED
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
  REFUNDED
}

enum ScanResult {
  OK
  ALREADY_USED
  INVALID_SIGNATURE
  NOT_FOUND
  CANCELLED
  WRONG_EVENT
  WRONG_TERMIN
  REFUNDED
}

enum TermsType {
  ORGANIZER_REGISTRATION
  BUYER_PURCHASE
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_TICKET
}

enum CouponScope {
  GLOBAL
  ORGANIZER
  SHOW
  TICKET_TYPE
}

// ─────────────────────────────────────────────
// TENANT – ORGANIZER
// ─────────────────────────────────────────────

model Organizer {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique  // used in URLs
  email            String          @unique
  phone            String?

  // Legal / billing
  ico              String?         // IČO
  dic              String?         // DIČ
  icoOrDic         String?         // combined for SK
  vatStatus        VatStatus       @default(NON_PAYER)
  iban             String?
  bankName         String?

  // Extended business info (KROK F)
  companyName      String?         // legal company name, e.g. "Acme s.r.o."
  icDph            String?         // IČ DPH, e.g. "SK1234567890"
  vatPayer         Boolean         @default(false)
  vatRate          Decimal?        @db.Decimal(5, 2)
  addressStreet    String?
  addressCity      String?
  addressZip       String?
  addressCountry   String?         @default("SK")
  bankAccount      String?         // IBAN for display on receipts

  // Payout / commission
  commissionPct    Decimal         @default(5.00) @db.Decimal(5, 2)
  payoutEmail      String?
  payoutNotes      String?

  // Per-organizátor fakturačná konfigurácia (LEN super-admin/staff – organizátor NEVIDÍ).
  // Krok 1/2: ukladáme; customerFeePercent sa aplikuje v checkoute až v kroku 2.
  commissionPercent  Decimal       @default(6.00)  @db.Decimal(5, 2)  // provízia % (náš podiel, bez DPH)
  vatPercent         Decimal       @default(23.00) @db.Decimal(5, 2)  // DPH % pre fakturáciu provízie (0 pri prenes. dani)
  feesIncluded       Boolean       @default(false)                    // s poplatkami / bez poplatkov
  customerFeePercent Decimal       @default(1.00)  @db.Decimal(5, 2)  // zákaznícky poplatok % (checkout, krok 2)
  // Fakturačný systém (krok 13a) – LEN super-admin (stripBilling); organizátor nevidí.
  billingMode             BillingMode @default(PER_EVENT)  // režim vyúčtovania
  refundFeePerTicketCents Int?                             // override poplatku za refund/lístok (cents); null = platformová konštanta (40)

  // Customisation
  ticketFooterText String?         // printed on every ticket
  logoUrl          String?
  websiteUrl       String?

  // Ticket template (JSON layout for ticket PDF/display – editor TBD)
  ticketTemplate   Json?           // organizer-level default

  status           OrganizerStatus @default(PENDING)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  users            User[]
  shows            Show[]
  venues           Venue[]
  orders           Order[]
  products         Product[]
  termsVersions    TermsVersion[]
  coupons          Coupon[]
  posClosures      PosClosure[]
  venueAccesses    VenueAccess[]
  invoices         Invoice[]

  @@index([status])
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String?   // null for OAuth-only accounts
  firstName      String?
  lastName       String?
  phone          String?
  role           UserRole  @default(CUSTOMER)

  // Non-null for ORGANIZER_* and SCANNER roles
  organizerId    String?
  organizer      Organizer? @relation(fields: [organizerId], references: [id])

  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  marketingOptIn Boolean   @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders               Order[]
  refreshTokens        RefreshToken[]
  termsAcceptances     TermsAcceptance[]
  scanLogs             ScanLog[]
  passwordResetTokens  PasswordResetToken[]
  createdCoupons       Coupon[]             @relation("CouponCreator")
  couponRedemptions    CouponRedemption[]
  posClosures          PosClosure[]

  @@index([organizerId])
  @@index([role])
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?  // set on logout / rotation
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique  // SHA-256 of the raw token sent to user
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// VENUE (miesto konania)
// ─────────────────────────────────────────────

model Venue {
  id           String     @id @default(cuid())
  // null organizerId = globálne miesto (SUPERADMIN-created, zdieľané všetkým organizátorom)
  organizerId  String?
  organizer    Organizer? @relation(fields: [organizerId], references: [id])

  name         String
  street       String?
  city         String?
  postalCode   String?
  country      String     @default("SK")
  lat          Decimal?   @db.Decimal(10, 7)
  lng          Decimal?   @db.Decimal(10, 7)
  capacity     Int?
  notes        String?

  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  termins      Termin[]
  seatMaps     SeatMap[]
  accesses     VenueAccess[]

  @@index([organizerId])
  @@index([city])
}

// ─────────────────────────────────────────────
// VENUE ACCESS (úloha 24): explicitné sprístupnenie miesta organizátorovi.
// Organizer vidí vlastné + sprístupnené; globálne (organizerId=null) už nie sú
// auto-viditeľné všetkým – iba ak ich SUPERADMIN sprístupní cez VenueAccess.
// ─────────────────────────────────────────────

model VenueAccess {
  id          String    @id @default(cuid())
  venueId     String
  venue       Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([venueId, organizerId])
  @@index([organizerId])
}

// ─────────────────────────────────────────────
// SHOW (podujatie / show – bez konkrétneho dátumu)
// ─────────────────────────────────────────────

model Show {
  id            String      @id @default(cuid())
  organizerId   String
  organizer     Organizer   @relation(fields: [organizerId], references: [id])

  // Content
  name          String
  slug          String      // unique within organizer
  description   String?     @db.Text
  category      String?

  // SEO
  seoTitle      String?
  seoDescription String?

  // Ticket template override for this show (overrides organizer-level template)
  ticketTemplate Json?

  isPromoted      Boolean     @default(false)
  sliderImageId   String?
  sliderImage     ShowImage?  @relation("ShowSliderImage", fields: [sliderImageId], references: [id])

  status        EventStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  images        ShowImage[]
  termins       Termin[]
  products      Product[]
  coupons       Coupon[]

  @@unique([organizerId, slug])
  @@index([organizerId, status])
  @@index([isPromoted])
}

// ─────────────────────────────────────────────
// SHOW IMAGE (galéria podujatia)
// ─────────────────────────────────────────────

model ShowImage {
  id          String   @id @default(cuid())
  showId      String
  show        Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  usedAsSliderIn Show[] @relation("ShowSliderImage")

  url         String   // main ~1200px wide WebP
  thumbUrl    String   // 600×400 crop WebP
  squareUrl   String   // 1000×1000 crop WebP (cover / listing)

  isCover     Boolean  @default(false)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([showId])
  @@index([showId, isCover])
}

// ─────────────────────────────────────────────
// TERMIN (konkrétny termín show)
// ─────────────────────────────────────────────

model Termin {
  id           String       @id @default(cuid())
  showId       String
  show         Show         @relation(fields: [showId], references: [id])
  venueId      String
  venue        Venue        @relation(fields: [venueId], references: [id])

  startsAt     DateTime
  endsAt       DateTime?
  doorsOpenAt  DateTime?
  timezone     String       @default("Europe/Bratislava")
  notes        String?

  status       TerminStatus @default(DRAFT)
  visible      Boolean      @default(true)
  capacity     Int?

  // Režim predaja (úloha 22 fáza 3a) – default GENERAL = dnešné správanie
  mode         TerminMode   @default(GENERAL)
  seatMapId    String?
  seatMap      SeatMap?     @relation(fields: [seatMapId], references: [id], onDelete: SetNull)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ticketTypes    TicketType[]
  orderItems     OrderItem[]
  tickets        Ticket[]
  scanLogs       ScanLog[]
  terminSections TerminSection[]
  terminSeats    TerminSeat[]

  @@index([showId])
  @@index([startsAt])
}

// ─────────────────────────────────────────────
// TICKET TYPE (typ vstupenky na termín)
// ─────────────────────────────────────────────

model TicketType {
  id                String    @id @default(cuid())
  terminId          String
  termin            Termin    @relation(fields: [terminId], references: [id])

  name              String    // "VIP", "Štandard", "Dieťa"
  description       String?
  price             Decimal   @db.Decimal(10, 2)
  currency          String    @default("EUR")  // ISO 4217
  totalQuantity     Int?      // null = unlimited
  maxPerOrder       Int       @default(10)

  // Sale window
  saleStartsAt      DateTime?
  saleEndsAt        DateTime?

  sortOrder         Int       @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orderItems        OrderItem[]
  tickets           Ticket[]
  coupons           Coupon[]

  @@index([terminId])
}

// ─────────────────────────────────────────────
// PRODUCT + VARIANT (merch)
// ─────────────────────────────────────────────

model Product {
  id           String           @id @default(cuid())
  organizerId  String
  organizer    Organizer        @relation(fields: [organizerId], references: [id])
  showId       String?          // optionally linked to a specific show
  show         Show?            @relation(fields: [showId], references: [id])

  name         String
  description  String?
  imageUrl     String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  variants     ProductVariant[]

  @@index([organizerId])
  @@index([showId])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id])

  name       String      // "S", "M", "L", "One size"
  sku        String?
  price      Decimal     @db.Decimal(10, 2)
  currency   String      @default("EUR")
  stock      Int?        // null = unlimited
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  orderItems OrderItem[]

  @@index([productId])
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique  // human-readable, e.g. MT-2024-00001
  organizerId   String
  organizer     Organizer   @relation(fields: [organizerId], references: [id])
  userId        String?     // null for guest checkout
  user          User?       @relation(fields: [userId], references: [id])

  // Buyer snapshot (denormalised for receipts)
  buyerEmail    String
  buyerName     String?
  buyerPhone    String?

  status        OrderStatus @default(PENDING)
  currency      String      @default("EUR")
  locale        String      @default("sk")  // jazyk kupujúceho zachytený pri checkoute (sk/en/cs) – pre e-maily (aj async Stripe webhook)
  totalAmount   Decimal     @db.Decimal(10, 2)  // subtotal - discountAmount (cena lístkov; bez poplatku)
  feeAmount     Decimal     @default(0) @db.Decimal(10, 2)  // zákaznícky poplatok za spracovanie (online checkout); grand total = totalAmount + feeAmount
  customerFeePct Decimal    @default(0) @db.Decimal(5, 2)   // aplikovaný % poplatku (audit; z Organizer.customerFeePercent v čase platby)
  discountAmount Decimal    @default(0) @db.Decimal(10, 2)  // 0 ak bez kupónu

  // Payment
  paymentProvider  String?   // "stripe", "mock", etc.
  paymentRef       String?   // provider session/transaction ID
  paidAt           DateTime?
  refundedAt       DateTime?
  expiresAt        DateTime? // PENDING orders expire at this time

  // Aplikovaný kupón (oddelená relácia od CouponRedemption – pre rýchly join + Stripe sumu)
  couponId      String?
  coupon        Coupon?     @relation(fields: [couponId], references: [id])

  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]
  tickets       Ticket[]
  couponRedemption CouponRedemption?
  refundRequests RefundRequest[]
  terminSeats   TerminSeat[]

  @@index([organizerId])
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([couponId])
  @@index([paymentProvider])
}

// ─────────────────────────────────────────────
// REFUND (žiadosť o vrátenie – audit trail, Úloha 20)
// ─────────────────────────────────────────────

model RefundRequest {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  requestedById String?   // userId customera (null ak admin/organizer inicioval)
  reason        String
  status        String    @default("REQUESTED") // REQUESTED/APPROVED/REJECTED/REFUNDED
  reviewedById  String?
  reviewNote    String?
  refundAmount  Decimal?  @db.Decimal(10, 2)
  requestedAt   DateTime  @default(now())
  reviewedAt    DateTime?
  refundedAt    DateTime?

  @@index([orderId])
  @@index([status])
}

// ─────────────────────────────────────────────
// POS CLOSURE (uzávierka pokladne – snapshot za obdobie)
// ─────────────────────────────────────────────

model PosClosure {
  id           String    @id @default(cuid())
  organizerId  String
  organizer    Organizer @relation(fields: [organizerId], references: [id])
  closedById   String
  closedBy     User      @relation(fields: [closedById], references: [id])

  periodFrom   DateTime  // koniec predošlej uzávierky (alebo prvý POS predaj)
  periodTo     DateTime  // moment uzávierky
  cashTotal    Decimal   @db.Decimal(10, 2)
  cardTotal    Decimal   @db.Decimal(10, 2)
  orderCount   Int
  ticketCount  Int
  note         String?

  createdAt    DateTime  @default(now())

  @@index([organizerId, createdAt])
}

// ─────────────────────────────────────────────
// ORDER ITEM (vstupenka alebo merch v objednávke)
// ─────────────────────────────────────────────

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id])

  // Exactly one of these is non-null:
  ticketTypeId     String?
  ticketType       TicketType?     @relation(fields: [ticketTypeId], references: [id])
  terminId         String?         // denorm for easier queries
  termin           Termin?         @relation(fields: [terminId], references: [id])

  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  // SEATMAP/SECTIONED položka (úloha 22 fáza 3a) – alternatíva k ticketTypeId
  terminSectionId  String?
  terminSection    TerminSection?  @relation(fields: [terminSectionId], references: [id])

  quantity         Int
  unitPrice        Decimal         @db.Decimal(10, 2)
  currency         String          @default("EUR")

  // Price snapshot at purchase time
  priceSnapshot    Json

  createdAt        DateTime        @default(now())

  tickets          Ticket[]

  @@index([orderId])
  @@index([ticketTypeId])
  @@index([terminSectionId])
}

// ─────────────────────────────────────────────
// TICKET (jednotlivá vstupenka s QR)
// ─────────────────────────────────────────────

model Ticket {
  id             String       @id @default(cuid())
  orderId        String
  order          Order        @relation(fields: [orderId], references: [id])
  orderItemId    String
  orderItem      OrderItem    @relation(fields: [orderItemId], references: [id])
  // ticketTypeId je nullable od úlohy 22/3a – SECTIONED lístok nemá TicketType (existujúce GENERAL dáta nedotknuté)
  ticketTypeId   String?
  ticketType     TicketType?  @relation(fields: [ticketTypeId], references: [id])
  terminId       String
  termin         Termin       @relation(fields: [terminId], references: [id])
  // SEATMAP/SECTIONED lístok (úloha 22 fáza 3a)
  terminSectionId String?
  terminSection   TerminSection? @relation(fields: [terminSectionId], references: [id])

  // QR payload: HMAC-SHA256 signed token (ticketId + terminId + nonce)
  qrToken        String       @unique
  nonce          String       @default(cuid())  // rotate on refund to invalidate printed QRs

  status         TicketStatus @default(VALID)
  usedAt         DateTime?    // set on first successful scan

  // Seat assignment (optional). seatId = väzba na konkrétne sedadlo (úloha 22 fáza 3b, SEATED).
  seatId         String?
  seat           Seat?        @relation(fields: [seatId], references: [id])
  seatSection    String?
  seatRow        String?
  seatNumber     String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  scanLogs       ScanLog[]

  @@index([orderId])
  @@index([terminId])
  @@index([status])
  @@index([seatId])
}

// ─────────────────────────────────────────────
// SCAN LOG (anti-passback audit trail)
// ─────────────────────────────────────────────

model ScanLog {
  id          String     @id @default(cuid())
  ticketId    String
  ticket      Ticket     @relation(fields: [ticketId], references: [id])
  terminId    String
  termin      Termin     @relation(fields: [terminId], references: [id])
  scannedById String?    // User (scanner role)
  scannedBy   User?      @relation(fields: [scannedById], references: [id])

  result      ScanResult
  deviceId    String?    // PWA device fingerprint
  ipAddress   String?
  scannedAt   DateTime   @default(now())

  @@index([ticketId])
  @@index([terminId])
  @@index([scannedAt])
}

// ─────────────────────────────────────────────
// TERMS & CONDITIONS (verziované)
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// STRIPE EVENT (idempotency log)
// ─────────────────────────────────────────────

model StripeEvent {
  id          String   @id   // Stripe event ID (evt_...)
  processedAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// HERO BANNER (marketing bannery na homepage)
// ─────────────────────────────────────────────

model HeroBanner {
  id          String    @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  ctaLabel    String?
  ctaUrl      String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  activeFrom  DateTime?
  activeUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

model TermsVersion {
  id           String     @id @default(cuid())
  organizerId  String?    // null = platform-wide terms
  organizer    Organizer? @relation(fields: [organizerId], references: [id])

  type         TermsType
  version      String     // e.g. "1.0", "2.1"
  content      String     @db.Text
  publishedAt  DateTime   @default(now())
  isActive     Boolean    @default(true)

  acceptances  TermsAcceptance[]

  @@index([type, isActive])
}

model TermsAcceptance {
  id             String       @id @default(cuid())
  termsVersionId String
  termsVersion   TermsVersion @relation(fields: [termsVersionId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  acceptedAt     DateTime     @default(now())
  ipAddress      String?
  userAgent      String?

  @@unique([termsVersionId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PLATFORM INFO (singleton – 1 row only)
// ─────────────────────────────────────────────

model PlatformInfo {
  id                  String   @id @default(cuid())
  legalName           String   @default("TicketAll s.r.o.")
  ico                 String?
  icDph               String?
  addressStreet       String?
  addressCity         String?
  addressZip          String?
  addressCountry      String?  @default("SK")
  defaultVatRateSk    Decimal  @default(20.00) @db.Decimal(5, 2)
  defaultVatRateCz    Decimal  @default(21.00) @db.Decimal(5, 2)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

// ─────────────────────────────────────────────
// PAYMENT GATEWAY (úloha 25): aktívna platobná brána (singleton).
// Default STRIPE_LIVE = dnešné správanie. ComGate = stub (príprava na migráciu).
// ─────────────────────────────────────────────

enum PaymentGateway {
  STRIPE_SANDBOX
  STRIPE_LIVE
  COMGATE_TEST
  COMGATE_LIVE
}

model PaymentGatewayConfig {
  id            String         @id @default(cuid())
  activeGateway PaymentGateway @default(STRIPE_LIVE)
  updatedById   String?        // audit – kto naposledy prepol (plain field, bez FK)
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())
}

// ─────────────────────────────────────────────
// COUPON (zľavové kupóny)
// ─────────────────────────────────────────────

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique

  type              CouponType
  // Hodnota: PERCENTAGE = 0-100 (15.50 = 15.5%), FIXED_AMOUNT = EUR, FREE_TICKET = vždy 100
  value             Decimal      @db.Decimal(10, 2)

  scope             CouponScope
  // Scope target IDs – iba jedno vyplnené podľa scope-u (validate v service)
  organizerId       String?
  organizer         Organizer?   @relation(fields: [organizerId], references: [id])
  showId            String?
  show              Show?        @relation(fields: [showId], references: [id])
  ticketTypeId      String?
  ticketType        TicketType?  @relation(fields: [ticketTypeId], references: [id])

  // Obmedzenia (všetky voliteľné)
  validFrom         DateTime?
  validUntil        DateTime?
  maxUses           Int?
  maxUsesPerUser    Int?
  minOrderAmount    Decimal?     @db.Decimal(10, 2)

  // Tracking
  usedCount         Int          @default(0)

  // Audit
  createdById       String
  createdBy         User         @relation("CouponCreator", fields: [createdById], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Bulk batch tracking (rovnaký batchId pre traceability)
  bulkBatchId       String?

  redemptions       CouponRedemption[]
  orders            Order[]

  @@index([code])
  @@index([scope, organizerId])
  @@index([showId])
  @@index([bulkBatchId])
}

model CouponRedemption {
  id             String   @id @default(cuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  userId         String?  // null pre guest checkout
  user           User?    @relation(fields: [userId], references: [id])
  discountAmount Decimal  @db.Decimal(10, 2)
  redeemedAt     DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Seat maps (úloha 22 fáza 1/5)
// Hala = Venue → viacero možných plánikov (SeatMap). Každá mapa má sekcie,
// sekcia je buď SECTIONED (len kapacita) alebo SEATED (menované sedadlá v radoch).
// Zatiaľ samostatná štruktúra na Venue – napojenie na Termin/predaj príde Fáza 3.
// ─────────────────────────────────────────────

enum SectionMode {
  SECTIONED // len kapacita (číslo), bez menovaných sedadiel
  SEATED    // menované sedadlá v radoch
}

model SeatMap {
  id        String    @id @default(cuid())
  venueId   String
  venue     Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name      String // napr. "Divadelné usporiadanie", "Stojací koncert"
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  sections  Section[]
  termins   Termin[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([venueId])
}

model Section {
  id           String      @id @default(cuid())
  seatMapId    String
  seatMap      SeatMap     @relation(fields: [seatMapId], references: [id], onDelete: Cascade)
  name         String // "Parter", "Balkón", "VIP", "Státie"
  mode         SectionMode
  capacity     Int? // len pre SECTIONED (NULL pre SEATED – odvodí sa z počtu sedadiel)
  displayOrder Int         @default(0)
  color        String? // hex pre budúci vizuál (Fáza 2)
  rows         Row[]
  terminSections TerminSection[]

  @@index([seatMapId])
}

model Row {
  id           String  @id @default(cuid())
  sectionId    String
  section      Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label        String // "A", "B", "1", "2"
  displayOrder Int     @default(0)
  seats        Seat[]

  @@index([sectionId])
}

model Seat {
  id           String  @id @default(cuid())
  rowId        String
  row          Row     @relation(fields: [rowId], references: [id], onDelete: Cascade)
  label        String // "A1", "12" – číslo sedadla v rade
  x            Float? // pozícia pre vizuál (Fáza 2)
  y            Float?
  isAccessible Boolean @default(false) // bezbariérové miesto

  terminSeats  TerminSeat[]
  tickets      Ticket[]

  @@index([rowId])
}

// ─────────────────────────────────────────────
// TERMIN SECTION (cena + dostupnosť sekcie per termín – úloha 22 fáza 3a)
// ─────────────────────────────────────────────

model TerminSection {
  id         String      @id @default(cuid())
  terminId   String
  termin     Termin      @relation(fields: [terminId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section     @relation(fields: [sectionId], references: [id])

  price      Decimal     @db.Decimal(10, 2) @default(0)
  currency   String      @default("EUR")

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([terminId, sectionId])
  @@index([terminId])
  @@index([sectionId])
}

// ─────────────────────────────────────────────
// TERMIN SEAT (obsadenosť konkrétneho sedadla per termín – úloha 22 fáza 3b, SEATED)
// ─────────────────────────────────────────────

enum SeatStatus {
  AVAILABLE // voľné
  HELD      // držané PENDING objednávkou (lock)
  SOLD      // predané (PAID)
}

model TerminSeat {
  id          String     @id @default(cuid())
  terminId    String
  termin      Termin     @relation(fields: [terminId], references: [id], onDelete: Cascade)
  seatId      String
  seat        Seat       @relation(fields: [seatId], references: [id])
  status      SeatStatus @default(AVAILABLE)
  orderId     String?    // objednávka ktorá sedadlo drží (HELD) / vlastní (SOLD)
  order       Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItemId String?    // pre fulfillment (sedadlá → ktorý OrderItem → tickety)
  heldAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([terminId, seatId])   // 1 riadok na sedadlo/termín – základ atomického claimu
  @@index([orderId])
  @@index([terminId, status])
}

// ─────────────────────── FAKTURAČNÝ SYSTÉM (krok 13b) ───────────────────────

model Invoice {
  id            String        @id @default(cuid())
  organizerId   String
  organizer     Organizer     @relation(fields: [organizerId], references: [id])

  status        InvoiceStatus @default(DRAFT)
  invoiceNumber String?       @unique  // NULL kým DRAFT; {YYYY}{NNNN} pri finalizácii

  billingMode   BillingMode               // snapshot režimu
  terminId      String?                   // PER_EVENT scope
  periodFrom    DateTime?                 // MONTHLY scope
  periodTo      DateTime?

  issueDate     DateTime      @default(now())  // dátum vystavenia
  taxDate       DateTime      @default(now())  // DUZP (dátum dodania)
  dueDate       DateTime                       // splatnosť (default issue +14)
  currency      String        @default("EUR")

  // Snapshot ODBERATEĽA (organizátor) – zmrazený pri finalizácii
  buyerName       String?
  buyerCompany    String?
  buyerIco        String?
  buyerDic        String?
  buyerIcDph      String?
  buyerAddress    String?
  buyerIban       String?

  // Súčty (cents)
  subtotalCents Int           @default(0)
  vatTotalCents Int           @default(0)
  totalCents    Int           @default(0)

  // Snapshot VÝPISU (informačné na PDF) – zmrazený pri finalizácii
  snapTicketsSold     Int     @default(0)
  snapRevenueCents    Int     @default(0)
  snapRefundedTickets Int     @default(0)
  snapNetPayoutCents  Int     @default(0)

  note          String?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems     InvoiceLineItem[]

  @@index([organizerId])
  @@index([status])
}

model InvoiceLineItem {
  id            String          @id @default(cuid())
  invoiceId     String
  invoice       Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  type          InvoiceLineType
  description   String
  quantity      Int             @default(1)
  unitPriceCents Int
  vatPercent    Decimal         @db.Decimal(5, 2)
  lineNetCents  Int
  lineVatCents  Int
  lineTotalCents Int
  sortOrder     Int             @default(0)

  @@index([invoiceId])
}
