# Maxiticket – Caddyfile

{
  email info@maxiticket.sk
  # Uncomment for staging (avoids LE rate limits during testing):
  # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ── API ────────────────────────────────────────────────
api.maxiticket.africa {
  reverse_proxy backend:3001

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip

  log {
    output file /data/logs/api-access.log {
      roll_size 50mb
      roll_keep 7
    }
  }
}

# ── Public web ─────────────────────────────────────────
maxiticket.africa, www.maxiticket.africa {
  reverse_proxy frontend:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}

# ── Admin + Organizer portal ───────────────────────────
admin.maxiticket.africa {
  reverse_proxy frontend:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}

# ── Mailpit (dev email UI) ─────────────────────────────
mail.maxiticket.africa {
  reverse_proxy mailpit:8025

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}

