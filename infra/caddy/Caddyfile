# TicketAll – Caddyfile

{
  email info@ticketall.eu
}

# ── API ────────────────────────────────────────────────
api.ticketall.eu {
  reverse_proxy backend:3001

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip

  log {
    output file /data/logs/api-access.log {
      roll_size 50mb
      roll_keep 7
    }
  }
}

# ── Public web ─────────────────────────────────────────
ticketall.eu, www.ticketall.eu {
  reverse_proxy frontend:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}

# ── Admin + Organizer portal ───────────────────────────
admin.ticketall.eu {
  reverse_proxy frontend:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}

# ── Scanner PWA ────────────────────────────────────────
skener.ticketall.eu {
  reverse_proxy frontend:3000

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}
