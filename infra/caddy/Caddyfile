# Maxiticket – Caddyfile
# Replace api.example.com and app.example.com with real domains
# Caddy handles Let's Encrypt automatically

{
  email info@maxiticket.sk
  # Uncomment for staging (avoids LE rate limits during testing):
  # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

api.example.com {
  reverse_proxy backend:3001 {
    health_uri /health
    health_interval 15s
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip

  log {
    output file /data/logs/api-access.log {
      roll_size 50mb
      roll_keep 7
    }
  }
}

app.example.com {
  reverse_proxy frontend:3000 {
    health_uri /api/health
    health_interval 15s
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
  }

  encode zstd gzip
}
