# Copy to /opt/maxiticket/.env and fill in values
# Never commit .env to git

# PostgreSQL
POSTGRES_USER=maxiticket
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=maxiticket

# Redis
REDIS_PASSWORD=changeme_redis_password

# Backend
DATABASE_URL=postgresql://maxiticket:changeme_strong_password@postgres:5432/maxiticket?schema=public
REDIS_URL=redis://:changeme_redis_password@redis:6379
JWT_SECRET=changeme_jwt_secret_min_32chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32chars
NODE_ENV=production
PORT=3001

# Storage (brand-neutral – images stored as relative paths, prefixed at API response time)
PUBLIC_API_URL=https://api.ticketall.eu

# Email
MAIL_TRANSPORT=smtp
SMTP_HOST=mail.webglobe.sk
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@ticketall.eu
SMTP_PASS=
MAIL_FROM="TicketAll <info@ticketall.eu>"
APP_BASE_URL=https://ticketall.eu
EMAIL_BASE_URL=https://ticketall.eu
QR_HMAC_SECRET=changeme_hmac_secret_min_32chars

# Payment
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=           # sk_live_... from Stripe Dashboard → API keys (LIVE MODE)
STRIPE_WEBHOOK_SECRET=       # whsec_... from Stripe Dashboard → Webhooks (LIVE MODE)
ORDER_EXPIRY_MINUTES=30      # PENDING orders expire after this many minutes

# Frontend
NEXT_PUBLIC_API_URL=https://api.ticketall.eu

# Domains
DOMAIN_API=api.ticketall.eu
DOMAIN_APP=ticketall.eu
DOMAIN_ADMIN=admin.ticketall.eu
DOMAIN_SCANNER=skener.ticketall.eu

# AI asistent (chat) – provider za abstrakciou ASSISTANT_LLM
ASSISTANT_PROVIDER=anthropic          # anthropic (default) | openai
ASSISTANT_MODEL=claude-sonnet-5          # Claude model pre tool-use (Sonnet 5 = kvalitnejší; Haiku 4.5 = rýchly/lacný)
ANTHROPIC_API_KEY=                    # Claude API kľúč (povinný pre ASSISTANT_PROVIDER=anthropic)
OPENAI_API_KEY=                       # fallback provider (ASSISTANT_PROVIDER=openai)

# Telegram notifikácie (AI konverzácie) – token bota od @BotFather. Prázdne = vypnuté.
# chatId + enabled sa nastavujú v admin UI (uložené v DB, NIE tu).
TELEGRAM_BOT_TOKEN=

# Helpdesk – IMAP poller (krok 29). Číta odpovede zákazníkov na tikety HD-….
# POZOR: schránka je bežná firemná pošta, nie vyhradený helpdesk. Poller ju
# otvára READ-ONLY, nič v nej nemení a spracuje LEN maily spárované s existujúcim
# tiketom – z nespárovaných NIKDY nezakladá nový.
HELPDESK_ENABLED=false                # feature flag; false = poller vôbec neštartuje
HELPDESK_IMAP_HOST=mail.webglobe.sk
HELPDESK_IMAP_PORT=993                # IMAPS (Hetzner blokuje 465/25, 993 je overene priechodne)
HELPDESK_IMAP_USER=                   # zvyčajne rovnaké ako SMTP_USER
HELPDESK_IMAP_PASS=                   # heslo k schránke
HELPDESK_IMAP_POLL_SEC=60             # interval pollovania v sekundách
